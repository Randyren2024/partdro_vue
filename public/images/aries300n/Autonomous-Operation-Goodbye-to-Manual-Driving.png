    /* Loop Header样式 */
    .blog-block-header .ekit-wid-con .ekit-btn-wraper>.elementskit-btn {
        padding: 0;
    }

    .blog-block-header .ekit-wid-con .ekit-btn-wraper>.elementskit-btn:hover {
        background-color: #ffffff;
        color: #1a66e5;
        fill: #1a66e5;
    }

    .blog-block-header .ekit-wid-con .ekit-btn-wraper .e-font-icon-svg {
        width: 12px;
        height: 10px;
    }

    /* 移动端卡片悬浮阴影清除，添加类名blog-item在loop item上 */
    /* .elementor-loop-container .blog-item:hover {
    box-shadow: none !important;
  } */
    .blog-item .elementor-icon-list-text {
        font-size: 14px;
        line-height: 130%;
    }

    .allynav__scroll__margin__top {
        scroll-margin-top: 81px;
    }

    /* 分页器移动端 */
    .allynav__blogs__pagination .elementor-pagination {
        gap: 31px;
    }

    .allynav__blogs__pagination .elementor-pagination .page-numbers.prev,
    .allynav__blogs__pagination .elementor-pagination .page-numbers.next {
        width: 48px;
        height: 48px;
    }

    .allynav__blogs__pagination .elementor-pagination .page-numbers.prev svg,
    .allynav__blogs__pagination .elementor-pagination .page-numbers.next svg {
        width: 14px;
        height: 12px;
    }

    .allynav__blogs__pagination .elementor-pagination .page-numbers {
        font-size: 14px;
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

    /* 活跃FAQ */
    .allynav__blog__detail__accordion .active .ekit-accordion-title {
        font-weight: 700 !important;
    }
}

@media (max-width: 1260px) {

    /* 搜索框样式调整 作用于Blog News Videos Events */
    .allynav__blog__search .eael-advanced-search-widget .eael-advanced-search-form .eael-advanced-search-wrap .icon {
        left: 12px;
        font-size: 12px;
    }

    .allynav__blog__search {
        position: relative;
        bottom: 22px;
    }

    .allynav__blog__search .eael-advanced-search-widget .eael-advanced-search-form.eael-advanced-search-form-style-1 .eael-advanced-search-wrap .eael-advanced-search {
        padding-left: 36px;
    }

    .allynav__blog__search .eael-advanced-search-widget .eael-advanced-search-form.eael-advanced-search-form-style-1 .eael-advanced-search-wrap .eael-advanced-search {
        border-radius: 6px;
        font-size: 14px;
        line-height: 140%;
        padding-top: 12px;
        padding-bottom: 12px;
        /* box-shadow: 2px 2px 6px 0px rgba(0, 0, 0, 0.08),
      1px 2px 20px 0px rgba(0, 0, 0, 0.06); */
    }

    .allynav__blog__search .eael-advanced-search-widget .eael-advanced-search-form.eael-advanced-search-form-style-1 .eael-advanced-search-wrap .eael-advanced-search::placeholder {
        font-size: 14px;
        line-height: 140%;
    }

    .allynav__blog__search .eael-advanced-search-wrap .icon {
        font-size: none !important;
    }

    .allynav__blog__search .eael-advanced-search-wrap .icon svg {
        width: 12px;
        height: 12px;
    }

    /* Video item span字体样式不生效 */
    .video-item .elementor-icon-list-items .elementor-icon-list-item span.elementor-icon-list-text {
        font-size: 14px !important;
    }
}

@media (max-width: 1260px) {
    /* 移动端 Swiper卡片 图片高度释放  */
    /* .allynav__swiper.swiper-img img,
  .resource__swiper.swiper-img img {
    height: auto !important;
  } */
    /* 移动端 Swiper卡片 图片高度释放  */
    /* .allynav__swiper.swiper-img .has_ae_slider {
    --min-height: auto !important;
  } */
}

@media (max-width: 1260px) {

    /* Previous Post模块 */
    .allynav__blog__nav .elementor-post-navigation__link__prev img,
    .allynav__blog__nav .elementor-post-navigation__link__next img {
        display: none;
    }

    .allynav__blog__nav .elementor-post-navigation__link__prev .post-navigation__prev--text .post-navigation__prev--title,
    .allynav__blog__nav .elementor-post-navigation__link__next .post-navigation__next--text .post-navigation__next--title {
        display: none !important;
    }

    .allynav__blog__nav .elementor-post-navigation__link__prev .post-navigation__prev--text .post-navigation__prev--label,
    .allynav__blog__nav .elementor-post-navigation__link__next .post-navigation__next--text .post-navigation__next--label {
        color: rgba(0, 0, 0, 0.5) !important;
        font-family: Poppins;
        font-size: 14px;
        font-style: normal;
        font-weight: 600;
        line-height: 130%;
    }

    .allynav__blog__nav .post-navigation__prev--text,
    .post-navigation__next--text {
        padding: 0px;
    }

    .allynav__blog__nav .elementor-post-navigation__link__prev .post-navigation__arrow-wrapper svg,
    .allynav__blog__nav .elementor-post-navigation__link__next .post-navigation__arrow-wrapper svg {
        width: 20px;
        height: 18px;
        fill: rgba(0, 0, 0, 0.5);
    }

    .allynav__blog__nav .elementor-post-navigation__link__prev .post-navigation__arrow-wrapper svg path,
    .allynav__blog__nav .elementor-post-navigation__link__next .post-navigation__arrow-wrapper svg path {
        fill: rgba(0, 0, 0, 0.5);
    }

    /* Event样式 */
    .allynav__month__cateogry .elementor-widget-elementskit-button {
        width: calc((100% - 36px) / 4);
    }

    .allynav__month__cateogry:not(.expanded) .elementor-widget-elementskit-button:nth-of-type(n + 4) {
        display: none;
    }

    /* SitemMap 内容块渐变背景色 */
    .content-bg {
        background: linear-gradient(180deg,
                rgba(26, 102, 229, 0.06) 0%,
                rgba(26, 102, 229, 0) 30%,
                rgba(26, 102, 229, 0) 100%);
    }

    .allynav__scroll__sitemap,
    .allynav__faqs__item {
        scroll-margin-top: 85px;
    }

    /* FAQ样式 */
    .faq-list .ekit-wid-con .ekit_accordion_icon_group {
        position: initial !important;
    }

    .faq-list .elementskit-card-body.ekit-accordion--content {
        margin: 0px 12px !important;
    }

    .faq-list .ekit-wid-con .elementskit-accordion .ekit-accordion-title {
        padding-right: 0px;
    }

    .faq-list .elementskit-card-header .ekit-accordion--toggler {
        display: flex;
        justify-content: space-between;
    }

    /* About Us */
    .about-list ul {
        margin: 0;
        padding-left: 22px;
    }

    .about-list ul li,
    .about-list ul li:hover {
        margin-bottom: 12px;
        border: none;
        color: #ffffff;
    }

    .about__swiper .e-n-carousel.swiper {
        max-width: 100%;
    }

    .about__swiper .ae-swiper-outer-wrapper {
        /* padding-right: 24px; */
    }

    .allynav__about__collaborations img {
        width: 63px;
        height: 63px;
        margin: 0;
    }

    .eael-breadcrumbs__content {
        padding: 0 !important;
    }

    .about-map {
        margin-top: -1px;
    }

    .about-pagination .swiper-pagination {
        position: unset;
        margin-top: 12px;
        padding-right: 24px;
    }
}

