		<div data-particle_enable="false" data-particle-mobile-disabled="false" class="has_ae_slider elementor-element elementor-element-01c895e e-con-full allynav__header__glass e-flex ae-bg-gallery-type-default e-con e-child" data-id="01c895e" data-element_type="container" data-e-type="container" data-settings="{&quot;ekit_has_onepagescroll_dot&quot;:&quot;yes&quot;}">
				<div class="elementor-element elementor-element-5a8ebac elementor-widget elementor-widget-html" data-id="5a8ebac" data-element_type="widget" data-e-type="widget" data-settings="{&quot;ekit_we_effect_on&quot;:&quot;none&quot;}" data-widget_type="html.default">
				<div class="elementor-widget-container">
					<style>
  /* ==================== 吸顶导航样式 ==================== */
  .allynav__header {
    z-index: 999;
    transition: all 0.3s ease;
  }

  .allynav__header--fixed {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
  }

  /* ==================== 搜索框样式 ==================== */
  .allynav__header__search__box {
    position: fixed;
    right: 20%;
    width: 400px;
    max-width: 60%;
    padding: 0 12px;
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
    background: white;
    border-radius: 8px;
  }

  .allynav__header__search__box .eael-advanced-search-widget {
    margin: 0;
    padding: 0;
  }

  .allynav__header__search__box
    .eael-advanced-search-widget
    .eael-advanced-search-form.eael-advanced-search-form-style-3 {
    padding: 10px 20px;
    background: transparent;
    border: none;
  }

  .allynav__header__search__box
    .eael-advanced-search-widget
    .eael-advanced-search-form
    .eael-advanced-search-wrap
    .icon {
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 24px;
  }

  .allynav__header__search__box
    .eael-advanced-search-widget
    .eael-advanced-search-form
    .eael-advanced-search-wrap
    .icon
    + .eael-advanced-search {
    padding: 0 60px 0 30px;
    height: 44px;
    font-size: 16px;
  }

  .allynav__header__search__btn {
    display: block;
    cursor: pointer;
    z-index: 1001;
    transition: opacity 0.3s ease;
  }

  .show-input .allynav__header__search__box,
  .allynav__header__search__box.show-mobile {
    opacity: 1;
    visibility: visible;
  }

  .show-input .allynav__header__search__btn {
    display: none;
  }

  @media (max-width: 1260px) {
    .allynav__header__search__box {
      top: 12px;
      left: 0;
      width: 100% !important;
      max-width: none;
      padding: 0 12px;
      border-radius: 0;
    }

    .allynav__header__search__btn {
      z-index: 1001;
    }

    .allynav__header__search__box
      .eael-advanced-search-widget
      .eael-advanced-search-form.eael-advanced-search-form-style-3 {
      padding: 0 10px;
    }
  }
</style>
<script defer>
    document.addEventListener("DOMContentLoaded", function () {
  const header = document.querySelector(".allynav__header");
  if (!header) return;

  let ticking = false;
  let headerOffsetTop = header.offsetTop;
  let headerHeight = header.offsetHeight;

  function updateHeaderPosition() {
    const currentScrollY = window.scrollY;
    const shouldFix = currentScrollY >= headerOffsetTop;

    if (shouldFix) {
      if (!header.classList.contains("allynav__header--fixed")) {
        header.classList.add("allynav__header--fixed");
        document.body.style.paddingTop = headerHeight + "px";
      }
    } else {
      if (header.classList.contains("allynav__header--fixed")) {
        header.classList.remove("allynav__header--fixed");
        document.body.style.paddingTop = "0";
      }
    }
  }

  function handleScroll() {
    if (!ticking) {
      requestAnimationFrame(function () {
        updateHeaderPosition();
        ticking = false;
      });
      ticking = true;
    }
  }

  window.addEventListener("scroll", handleScroll);

  const resizeObserver = new ResizeObserver(() => {
    headerOffsetTop = header.offsetTop;
    headerHeight = header.offsetHeight;
    if (header.classList.contains("allynav__header--fixed")) {
      document.body.style.paddingTop = headerHeight + "px";
    }
  });

  resizeObserver.observe(header);
  resizeObserver.observe(document.body);

  const btn = document.querySelector(".allynav__header__search__btn");
  const inputContainer = document.querySelector(".allynav__header__search__box");
  const inputElement = inputContainer?.querySelector(".eael-advanced-search");

  if (btn && inputContainer) {
    btn.addEventListener("click", (e) => {
      e.preventDefault();
      inputContainer.style.opacity = "1";
      inputContainer.style.visibility = "visible";
      btn.style.display = "none";
      if (inputElement) inputElement.focus();
    });

    document.addEventListener("click", (e) => {
      const clickedInside = inputContainer.contains(e.target) || btn.contains(e.target);
      if (!clickedInside) {
        inputContainer.style.opacity = "0";
        inputContainer.style.visibility = "hidden";
        btn.style.display = "block";
      }
    });

    if (inputElement) {
      inputElement.addEventListener("blur", () => {
        setTimeout(() => {
          if (document.activeElement !== inputElement) {
            inputContainer.style.opacity = "0";
            inputContainer.style.visibility = "hidden";
            btn.style.display = "block";
          }
        }, 100);
      });

      inputElement.addEventListener("keydown", function (e) {
        if (e.key === "Enter" || e.keyCode === 13) {
          e.preventDefault();
        }
      });
    }
  }

  window.addEventListener("load", () => {
    headerOffsetTop = header.offsetTop;
    headerHeight = header.offsetHeight;
    if (window.scrollY >= headerOffsetTop && header.classList.contains("allynav__header--fixed")) {
      document.body.style.paddingTop = headerHeight + "px";
    }
  });
});
</script>				</div>
