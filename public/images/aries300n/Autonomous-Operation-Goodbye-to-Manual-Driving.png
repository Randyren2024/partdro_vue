			<script>
(function () {
  'use strict';

  /**
   * 初始化所有密码切换按钮
   */
  function initPasswordToggleButtons() {
    document.querySelectorAll('.show-password-input').forEach(function (btn) {
      if (!btn.textContent.trim()) {
        btn.textContent = '👁️';
        btn.setAttribute('aria-label', 'Show password');
      }
    });
  }

  /**
   * 切换密码字段可见性
   * @param {HTMLElement} button - 触发按钮
   */
  function togglePasswordVisibility(button) {
    const passwordField = document.getElementById('password_current');
    if (!passwordField) return;

    const isCurrentlyPassword = passwordField.type === 'password';
    passwordField.type = isCurrentlyPassword ? 'text' : 'password';

    if (isCurrentlyPassword) {
      button.textContent = '🙈';
      button.setAttribute('aria-label', 'Hide password');
    } else {
      button.textContent = '👁️';
      button.setAttribute('aria-label', 'Show password');
    }
  }

  // 页面加载后初始化密码按钮
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPasswordToggleButtons);
  } else {
    initPasswordToggleButtons();
  }

  // 监听 WooCommerce AJAX 事件
  document.addEventListener('updated_wc_div', initPasswordToggleButtons);
  document.addEventListener('wc_fragments_loaded', initPasswordToggleButtons);
  document.addEventListener('wc_fragments_refreshed', initPasswordToggleButtons);

  // 事件委托处理点击
  document.addEventListener('click', function (e) {
    if (e.target.classList.contains('show-password-input')) {
      togglePasswordVisibility(e.target);
    }
  });

  // MutationObserver 兜底
  const observer = new MutationObserver(function (mutations) {
    let shouldInit = false;
    for (let mutation of mutations) {
      if (mutation.type === 'childList') {
        for (let node of mutation.addedNodes) {
          if (node.nodeType === 1) {
            if (
              node.classList?.contains('show-password-input') ||
              node.querySelector?.('.show-password-input')
            ) {
              shouldInit = true;
              break;
            }
          }
        }
        if (shouldInit) break;
      }
    }
    if (shouldInit) {
      initPasswordToggleButtons();
    }
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });

  /**
   * 控制 .allynav__inquiry 元素的显示/隐藏
   */
  function toggleInquiryOnScroll() {
    const inquiryElements = document.querySelectorAll('.allynav__inquiry');
    if (inquiryElements.length === 0) return;

    const isVisible = window.scrollY > 400;
    inquiryElements.forEach(el => {
      el.classList.toggle('visible', isVisible);
    });
  }

  // 初始化状态（防止页面刷新时已在下方）
  toggleInquiryOnScroll();

  // 监听滚动事件（使用 passive 提升性能）
  window.addEventListener('scroll', toggleInquiryOnScroll, { passive: true });

})();
</script>
<script defer>
/**
 * 初始化标签页（Tabs）交互功能
 * 功能包括：
 * - 点击标签标题切换内容
 * - 鼠标悬停标签标题（带防抖）切换内容
 * - 正确处理标签内的链接点击，避免冲突
 */
document.addEventListener("DOMContentLoaded", function () {
  'use strict'; // 启用严格模式

  // --- 配置 ---
  const HOVER_DELAY_MS = 150; // 鼠标悬停切换的延迟时间（毫秒）

  // --- 状态管理 ---
  let hoverTimeout = null; // 用于存储 hover 切换的延迟定时器

  // --- DOM 元素获取 ---
  const tabButtons = document.querySelectorAll(".allynav__mega__solutions .e-n-tab-title");

  // --- 初始化检查 ---
  if (!tabButtons.length) {
    console.warn('No tab buttons found for selector: .allynav__mega__solutions .e-n-tab-title');
    return; // 如果没有找到任何 tab 按钮，直接退出
  }

  // --- 事件绑定 ---
  tabButtons.forEach((currentTabButton) => {

    // --- 点击事件处理 ---
    currentTabButton.addEventListener("click", function (event) {
      // 检查点击目标是否是链接或其子元素
      const clickedAnchor = event.target.closest("a");
      if (clickedAnchor) {
        // 如果是链接，允许默认跳转行为，不执行 tab 切换
        return;
      }

      // 阻止默认行为（如页面跳转等）
      event.preventDefault();
      // 执行 tab 切换逻辑
      handleTabSwitch(currentTabButton);
    });

    // --- 鼠标进入事件处理 (Hover) ---
    currentTabButton.addEventListener("mouseenter", function (event) {
      // 检查悬停目标是否是链接或其子元素
      const hoveredAnchor = event.target.closest("a");
      if (hoveredAnchor) {
        // 如果悬停在链接上，不清除定时器也不切换
        return;
      }

      // 阻止可能的默认行为
      event.preventDefault();

      // 清除之前设置的延迟任务，防止快速移动鼠标导致的意外切换
      clearTimeout(hoverTimeout);

      // 设置新的延迟切换任务
      hoverTimeout = setTimeout(() => {
        handleTabSwitch(currentTabButton);
      }, HOVER_DELAY_MS);
    });

    // --- 鼠标离开事件处理 ---
    currentTabButton.addEventListener("mouseleave", function () {
       // 鼠标离开时，清除已设置的延迟任务
      clearTimeout(hoverTimeout);
    });

    // --- 链接特殊处理 ---
    // 为 tab 内的 <a> 标签单独添加点击监听，防止事件冒泡触发父级按钮的 click 事件
    const tabLink = currentTabButton.querySelector("a");
    if (tabLink) {
      tabLink.addEventListener("click", function (event) {
        // 阻止事件向上冒泡到 tab 按钮
        event.stopPropagation();
      });
    }
  });

  /**
   * 核心函数：处理 tab 的切换逻辑
   * @param {HTMLElement} activeTabButton - 用户交互（点击/悬停）的当前 tab 按钮元素
   */
  function handleTabSwitch(activeTabButton) {
    // --- 获取关联信息 ---
    const targetContentId = activeTabButton.getAttribute("aria-controls");
    if (!targetContentId) {
      console.error('Tab button missing aria-controls attribute:', activeTabButton);
      return; // 必须有 aria-controls 属性才能知道切换到哪个内容
    }

    // --- 查找内容容器 ---
    const tabsWrapper = activeTabButton.closest(".e-n-tabs");
    if (!tabsWrapper) {
       console.error('Tab button not inside an element with class .e-n-tabs:', activeTabButton);
       return;
    }
    const tabContentContainer = tabsWrapper.querySelector(".e-n-tabs-content");
    if (!tabContentContainer) {
       console.error('Could not find .e-n-tabs-content within the tab wrapper.');
       return;
    }


    // --- 1. 更新所有 Tab 按钮的状态 ---
    const tabHeadingContainer = activeTabButton.closest(".e-n-tabs-heading");
    if (tabHeadingContainer) {
      const allTabButtonsInGroup = tabHeadingContainer.querySelectorAll(".e-n-tab-title");
      allTabButtonsInGroup.forEach((button) => {
        button.setAttribute("aria-selected", "false");
        button.classList.remove("e-active");
      });
    } else {
       console.warn('Could not find parent .e-n-tabs-heading for tab button:', activeTabButton);
    }

    // 激活当前被点击/悬停的 tab 按钮
    activeTabButton.setAttribute("aria-selected", "true");
    activeTabButton.classList.add("e-active");


    // --- 2. 更新所有内容面板的状态 ---
    const allContentPanels = tabContentContainer.querySelectorAll(":scope > div"); // 直接子 div 元素
    allContentPanels.forEach((panel) => {
      panel.classList.remove("e-active");
      panel.setAttribute("hidden", ""); // 隐藏所有内容面板
    });


    // --- 3. 显示对应的目标内容面板 ---
    const targetContentPanel = document.getElementById(targetContentId);
    if (targetContentPanel) {
      targetContentPanel.classList.add("e-active");
      targetContentPanel.removeAttribute("hidden"); // 显示目标内容
    } else {
       console.error(`Target content panel with ID '${targetContentId}' not found.`);
    }
  }
});
</script>
<script defer>
  const prevButton = document.querySelector(".allynav__blogs__pagination .elementor-pagination .prev");
  const nextButton = document.querySelector(".allynav__blogs__pagination .elementor-pagination .next");

  // 只有当元素存在时才修改 innerHTML
  if (prevButton) {
    prevButton.innerHTML == `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="16" viewBox="0 0 18 16" fill="none">
        <path d="M0.376696 9.10219C-0.125565 8.6141 -0.125565 7.82144 0.376696 7.33335L6.80562 1.08579C7.30789 0.597704 8.12356 0.597704 8.62582 1.08579C9.12808 1.57389 9.12808 2.36654 8.62582 2.85463L4.38674 6.97021H16.7142C17.4254 6.97021 18 7.52859 18 8.21973C18 8.91086 17.4254 9.46924 16.7142 9.46924H4.39076L8.6218 13.5848C9.12406 14.0729 9.12406 14.8656 8.6218 15.3537C8.11954 15.8417 7.30387 15.8417 6.80161 15.3537L0.372677 9.1061L0.376696 9.10219Z" fill="#333333"/>
      </svg>`;
