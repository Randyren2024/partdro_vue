	<meta name="generator" content="Elementor 3.35.7; features: e_font_icon_svg, additional_custom_breakpoints; settings: css_print_method-external, google_font-enabled, font_display-swap">
<script defer>
(function () {
  // ========== 配置 ==========
  const CONFIG = {
    TRACKING_PARAMS: [
      'gclid', 'gbraid', 'wbraid', 'gad_source', 'gad_campaignid',
      'utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content',
      'yclid'
    ],
    STORAGE_TTL: 1800, // 30分钟（秒）
    // true: 仅首次存储 (保持首次访问来源)
    // false: 总是更新存储 (使用最后访问来源)
    ONLY_STORE_IF_NOT_EXISTS: true
  };

  // ========== 工具函数 ==========
  function getParam(name) {
    try {
      const urlObj = new URL(window.location.href);
      let value = urlObj.searchParams.get(name);
      if (value === null) return null;
      if (name === 'gclid') value = value.split(',')[0];
      return value.trim() || null;
    } catch (error) {
      console.warn(`Error parsing parameter '${name}':`, error);
      return null;
    }
  }

  function setWithExpiry(key, value, ttlSeconds) {
    const item = { value: value, expiry: Date.now() + (ttlSeconds * 1000) };
    const itemStr = JSON.stringify(item);
    try {
      localStorage.setItem(key, itemStr);
      return;
    } catch (e1) {
      console.debug(`Failed localStorage for '${key}', trying sessionStorage...`, e1);
    }
    try {
      sessionStorage.setItem(key, itemStr);
    } catch (e2) {
       console.warn(`Failed both storages for '${key}'.`, e2);
    }
  }

  function getWithExpiry(key) {
    const storages = [localStorage, sessionStorage];
    for (const storage of storages) {
      try {
        const itemStr = storage.getItem(key);
        if (!itemStr) continue;
        const item = JSON.parse(itemStr);
        if (Date.now() > item.expiry) {
          storage.removeItem(key);
          console.debug(`Removed expired item '${key}'.`);
          continue;
        }
        return item.value;
      } catch (error) {
        console.warn(`Error reading '${key}' from storage. Removing item.`, error);
        storage.removeItem(key);
      }
    }
    return null;
  }

  // ========== 表单处理 ==========
  function clearTrackingData() {
    const storages = [localStorage, sessionStorage];
    storages.forEach(storage => {
      try {
        CONFIG.TRACKING_PARAMS.forEach(p => storage.removeItem(p));
        storage.removeItem('user_location');
      } catch (error) {
        console.warn("Error clearing tracking data:", error);
      }
    });
  }

  function fillFormsNow() {
    CONFIG.TRACKING_PARAMS.forEach(param => {
      const value = getWithExpiry(param);
      if (!value) return;

      document.querySelectorAll(`.allynav-${param}`).forEach(container => {
        const field = container.querySelector('input[type="hidden"]');
        if (field && !field.value) {
          field.value = value;
          ['input', 'change'].forEach(type =>
            field.dispatchEvent(new Event(type, { bubbles: true }))
          );
        }
      });
    });
  }

  function attachFormSubmitListeners() {
    document.querySelectorAll('form.wpforms-form').forEach(form => {
      form.addEventListener('submit', clearTrackingData, { once: true });
    });
  }

  // ========== 初始化参数捕获 ==========
  function captureAndStoreParamsOnInit() {
    CONFIG.TRACKING_PARAMS.forEach(param => {
      const current = getWithExpiry(param);
      const fromURL = getParam(param);
      if (CONFIG.ONLY_STORE_IF_NOT_EXISTS) {
        if (!current && fromURL) {
          setWithExpiry(param, fromURL, CONFIG.STORAGE_TTL);
        }
      } else {
        if (fromURL) {
          setWithExpiry(param, fromURL, CONFIG.STORAGE_TTL);
        }
      }
    });
  }
  captureAndStoreParamsOnInit();

  // ========== DOM 就绪后执行 ==========
  function onDomReady() {
    fillFormsNow();
    attachFormSubmitListeners();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', onDomReady);
  } else {
    onDomReady();
  }

})();
</script>

