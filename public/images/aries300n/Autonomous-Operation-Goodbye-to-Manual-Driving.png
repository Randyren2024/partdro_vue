  if (nextButton) {
    nextButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="16" viewBox="0 0 18 16" fill="none">
        <path d="M17.6233 9.10219C18.1256 8.6141 18.1256 7.82144 17.6233 7.33335L11.1944 1.08579C10.6921 0.597704 9.87644 0.597704 9.37418 1.08579C8.87192 1.57389 8.87192 2.36654 9.37418 2.85463L13.6133 6.97021H1.28579C0.574586 6.97021 0 7.52859 0 8.21973C0 8.91086 0.574586 9.46924 1.28579 9.46924H13.6092L9.3782 13.5848C8.87594 14.0729 8.87594 14.8656 9.3782 15.3537C9.88046 15.8417 10.6961 15.8417 11.1984 15.3537L17.6273 9.1061L17.6233 9.10219Z" fill="#333333"/>
      </svg>`;
  } 
</script>
<script defer>
(function () {
    function isMobileSize() {
        return window.innerWidth < 1260;
    }

    // ========= allynav__ae__swiper 专用逻辑（完全保留原样） =========
    function applyAESwiperSettings(container) {
        const swiperContainer = container.querySelector('.ae-swiper-container');
        if (!swiperContainer || !swiperContainer.swiper) return;

        const swiper = swiperContainer.swiper;
        const isSolutions = container.classList.contains('allynav__ae__swiper--solutions');
        const isProducts = container.classList.contains('allynav__ae__swiper--products');

        let slidesPerView = swiper.params.slidesPerView;
        let spaceBetween = swiper.params.spaceBetween;

        if (isMobileSize()) {
            slidesPerView = 1.25;
            spaceBetween = 12;
        } else {
            if (isSolutions) {
                slidesPerView = 3.25;
                spaceBetween = 24;
            } else if (isProducts) {
                slidesPerView = 2.5;
                spaceBetween = 24;
            }
        }

        swiper.params.slidesPerView = slidesPerView;
        swiper.params.slidesPerGroup = 1;
        swiper.params.spaceBetween = spaceBetween;

        const slides = swiper.slides || [];
        const shouldShowButtons = slides.length > slidesPerView;

        const prevBtn = container.querySelector('.ae-swiper-button-prev');
        const nextBtn = container.querySelector('.ae-swiper-button-next');

        if (prevBtn) prevBtn.style.display = shouldShowButtons ? '' : 'none';
        if (nextBtn) nextBtn.style.display = shouldShowButtons ? '' : 'none';

        swiper.update();
    }

    // ========= allynav__swiper 专用逻辑（完全保留原样） =========
    function applySwiperSettings(container) {
        const swiperContainer = container.querySelector('.swiper');
        if (!swiperContainer || !swiperContainer.swiper) return;

        const swiper = swiperContainer.swiper;
        const isResources = container.classList.contains('allynav__swiper--resources');

        let slidesPerView = swiper.params.slidesPerView;
        let spaceBetween = swiper.params.spaceBetween;

        if (isMobileSize()) {
            slidesPerView = 1.75;
            spaceBetween = 12;
            if (isResources) {
                slidesPerView = 1.25;
            }
        }

        swiper.params.slidesPerView = slidesPerView;
        swiper.params.slidesPerGroup = 1;
        swiper.params.spaceBetween = spaceBetween;

        const slides = swiper.slides || [];
        const slidesToShow = swiper.params.slidesPerView;
        const shouldShowButtons = slides.length > slidesToShow;

        const prevBtn = container.querySelector('.elementor-swiper-button-prev');
        const nextBtn = container.querySelector('.elementor-swiper-button-next');

        if (prevBtn) prevBtn.style.display = shouldShowButtons ? '' : 'none';
        if (nextBtn) nextBtn.style.display = shouldShowButtons ? '' : 'none';

        swiper.update();
    }

    // ========= 监听 allynav__ae__swiper 的初始化 =========
    function observeAESwiper(container) {
        const target = container.querySelector('.ae-swiper-container');
        if (!target) return;

        if (target.swiper) {
            applyAESwiperSettings(container);
            return;
        }

        const obs = new MutationObserver(() => {
            if (target.swiper) {
                obs.disconnect();
                applyAESwiperSettings(container);
            }
        });

        obs.observe(target, { childList: true, subtree: true });
    }

    // ========= 监听 allynav__swiper 的初始化 =========
    function observeStandardSwiper(container) {
        const target = container.querySelector('.swiper');
        if (!target) return;

        if (target.swiper) {
            applySwiperSettings(container);
            return;
        }

        const obs = new MutationObserver(() => {
            if (target.swiper) {
                obs.disconnect();
                applySwiperSettings(container);
            }
        });

        obs.observe(target, { childList: true, subtree: true });
    }

    // ========= 顶层 MutationObserver：监听新 swiper 容器插入 =========
    const mainObserver = new MutationObserver((mutations) => {
        for (const mutation of mutations) {
            for (const node of mutation.addedNodes) {
                if (node.nodeType !== Node.ELEMENT_NODE) continue;

                // 处理 allynav__ae__swiper
                if (node.matches && node.matches('.allynav__ae__swiper')) {
                    observeAESwiper(node);
                }
                if (node.querySelectorAll) {
                    node.querySelectorAll('.allynav__ae__swiper').forEach(observeAESwiper);
                }

                // 处理 allynav__swiper
                if (node.matches && node.matches('.allynav__swiper')) {
                    observeStandardSwiper(node);
                }
                if (node.querySelectorAll) {
                    node.querySelectorAll('.allynav__swiper').forEach(observeStandardSwiper);
                }
            }
        }
    });

    mainObserver.observe(document.body, { childList: true, subtree: true });

    // ========= 初始化时处理已存在的 swiper =========
    document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('.allynav__ae__swiper').forEach(observeAESwiper);
        document.querySelectorAll('.allynav__swiper').forEach(observeStandardSwiper);
    });

    // ========= Resize 事件（使用 requestAnimationFrame 防抖，无定时器） =========
    let resizeRAF;
    window.addEventListener('resize', () => {
        cancelAnimationFrame(resizeRAF);
        resizeRAF = requestAnimationFrame(() => {
            document.querySelectorAll('.allynav__ae__swiper').forEach(container => {
                if (container.querySelector('.ae-swiper-container')?.swiper) {
                    applyAESwiperSettings(container);
                }
            });
            document.querySelectorAll('.allynav__swiper').forEach(container => {
                if (container.querySelector('.swiper')?.swiper) {
                    applySwiperSettings(container);
                }
            });
        });
    });
})();
</script>
