        width: 12px;
        height: 10px;
    }

    /* 移动端卡片悬浮阴影清除，添加类名blog-item在loop item上 */
    /* .elementor-loop-container .blog-item:hover {
    box-shadow: none !important;
  } */
    .blog-item .elementor-icon-list-text {
        font-size: 14px;
        line-height: 130%;
    }

    .allynav__scroll__margin__top {
        scroll-margin-top: 81px;
    }

    /* 分页器移动端 */
    .allynav__blogs__pagination .elementor-pagination {
        gap: 31px;
    }

    .allynav__blogs__pagination .elementor-pagination .page-numbers.prev,
    .allynav__blogs__pagination .elementor-pagination .page-numbers.next {
        width: 48px;
        height: 48px;
    }

    .allynav__blogs__pagination .elementor-pagination .page-numbers.prev svg,
    .allynav__blogs__pagination .elementor-pagination .page-numbers.next svg {
        width: 14px;
        height: 12px;
    }

    .allynav__blogs__pagination .elementor-pagination .page-numbers {
        font-size: 14px;
        margin-left: 0 !important;
        margin-right: 0 !important;
    }

    /* 活跃FAQ */
    .allynav__blog__detail__accordion .active .ekit-accordion-title {
        font-weight: 700 !important;
    }
}

@media (max-width: 1260px) {

    /* 移动端Blog详情页 面包屑 */
    .allynav__blog__breadcrums .ekit-stylish-list-content-wrapper {
        display: none;
    }

    .allynav__blog__breadcrums .ekit-stylish-list-content-wrapper:nth-last-child(-n + 4) {
        display: inline-block;
        padding: 0 6px 0 0 !important;
    }

    .allynav__blog__breadcrums .ekit-stylish-list-content-wrapper:last-child {
        padding: 0px !important;
    }

    .allynav__blog__breadcrums .ekit-stylish-list-content-wrapper:last-child span {
        font-weight: 700 !important;
    }

    .allynav__blog__breadcrums .ekit-stylish-list::before {
        content: "…";
        display: inline-block;
        margin-right: 6px;
    }

    /* Previous Post模块 */
    .allynav__blog__nav .elementor-post-navigation__link__prev img,
    .allynav__blog__nav .elementor-post-navigation__link__next img {
        display: none;
    }

    .allynav__blog__nav .elementor-post-navigation__link__prev .post-navigation__prev--text .post-navigation__prev--title,
    .allynav__blog__nav .elementor-post-navigation__link__next .post-navigation__next--text .post-navigation__next--title {
        display: none !important;
    }

    .allynav__blog__nav .elementor-post-navigation__link__prev .post-navigation__prev--text .post-navigation__prev--label,
    .allynav__blog__nav .elementor-post-navigation__link__next .post-navigation__next--text .post-navigation__next--label {
        color: rgba(0, 0, 0, 0.5) !important;
        font-family: Poppins;
        font-size: 14px;
        font-style: normal;
        font-weight: 600;
        line-height: 130%;
    }

    .allynav__blog__nav .post-navigation__prev--text,
    .post-navigation__next--text {
        padding: 0px;
    }

    .allynav__blog__nav .elementor-post-navigation__link__prev .post-navigation__arrow-wrapper svg,
    .allynav__blog__nav .elementor-post-navigation__link__next .post-navigation__arrow-wrapper svg {
        width: 20px;
        height: 18px;
        fill: rgba(0, 0, 0, 0.5);
    }

    .allynav__blog__nav .elementor-post-navigation__link__prev .post-navigation__arrow-wrapper svg path,
    .allynav__blog__nav .elementor-post-navigation__link__next .post-navigation__arrow-wrapper svg path {
        fill: rgba(0, 0, 0, 0.5);
    }

    /* Event样式 */
    /* SitemMap 内容块渐变背景色 */
    .content-bg {
        background: linear-gradient(180deg,
                rgba(26, 102, 229, 0.06) 0%,
                rgba(26, 102, 229, 0) 30%,
                rgba(26, 102, 229, 0) 100%);
    }

    .allynav__scroll__sitemap,
    .allynav__faqs__item {
        scroll-margin-top: 85px;
    }

    /* FAQ样式 */
    .faq-list .ekit-wid-con .ekit_accordion_icon_group {
        position: initial !important;
    }

    .faq-list .elementskit-card-body.ekit-accordion--content {
        margin: 0px 12px !important;
    }

    .faq-list .ekit-wid-con .elementskit-accordion .ekit-accordion-title {
        padding-right: 0px;
    }

    .faq-list .elementskit-card-header .ekit-accordion--toggler {
        display: flex;
        justify-content: space-between;
    }

    /* About Us */
    .about-list ul {
        margin: 0;
        padding-left: 22px;
    }

    .about-list ul li,
    .about-list ul li:hover {
        margin-bottom: 12px;
        border: none;
        color: #ffffff;
    }

    .about__swiper .e-n-carousel.swiper {
        max-width: 100%;
    }

    .about__swiper .ae-swiper-outer-wrapper {
        /* padding-right: 24px; */
    }

    .allynav__about__collaborations img {
        width: 63px;
        height: 63px;
        margin: 0;
    }

    .eael-breadcrumbs__content {
        padding: 0 !important;
    }

    .policy-text h2 {
        font-size: 16px !important;
    }

    .policy-text h2:first-of-type {
        margin-top: 24px !important;
    }

    .policy-text p {
        font-size: 14px !important;
    }

    .about-map {
        margin-top: -1px;
    }

    .about-pagination .swiper-pagination {
        position: unset;
        margin-top: 12px;
        padding-right: 24px;
    }
}		</style>
