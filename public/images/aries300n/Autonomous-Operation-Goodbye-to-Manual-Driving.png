    .title-weight h2,
    .title-weight h2.allynav__title,
    .blog-item h3.elementor-heading-title>a,
    .title-weight .ekit-btn-wraper,
    .event-item h3,
    .title-weight h3,
    .allynav__accordion__events .e-n-accordion-item-title-header .e-n-accordion-item-title-text {
        font-weight: 600 !important;
    }

    /* Search搜索框样式 */
