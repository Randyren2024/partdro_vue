				<div class="elementor-widget-container">
					<style>
/* 默认隐藏内容块并设置溢出隐藏 */
.allynav__footer__accordion__content {
  overflow: hidden;
}

/* 移动端（≤1260px）样式 */
@media (max-width: 1260px) {
  .allynav__footer__accordion__content {
    display: none;
  }

  /* 显示加号图标 */
  .allynav__footer__accordion__title__plus {
    display: inline-flex;
  }

  .allynav__footer__accordion__title__minus {
    display: none;
  }
}

/* PC端（>1260px）：隐藏所有图标 */
@media (min-width: 1261px) {
  .allynav__footer__accordion__title__plus,
  .allynav__footer__accordion__title__minus {
    display: none !important;
  }
}
</style>
<script defer>
document.addEventListener('DOMContentLoaded', function () {
  let accordionInitialized = false;

  function maybeInitAccordion() {
    const isMobile = window.innerWidth < 1260;

    if (isMobile && !accordionInitialized) {
      initAccordion();
      accordionInitialized = true;
    } else if (!isMobile && accordionInitialized) {
      destroyAccordion();
      accordionInitialized = false;
    }
  }

  function initAccordion() {
    const titles = document.querySelectorAll('.allynav__footer__accordion__title');
    if (!titles.length) return;

    setDefaultExpandedItem(titles[0]);

    titles.forEach(title => {
      if (title._accordionListener) return;

      const listener = function () {
        const content = findNextContent(this);
        if (!content) return;

        const isVisible = window.getComputedStyle(content).display !== 'none';

        closeAllAccordions();

        if (!isVisible) {
          content.style.display = 'flex';
          toggleIcons(this, true);
        }
      };

      title.addEventListener('click', listener);
      title._accordionListener = listener;
    });
  }

  function setDefaultExpandedItem(title) {
    const content = findNextContent(title);
    if (content) {
      content.style.display = 'flex';
      toggleIcons(title, true);
    }
  }

  function findNextContent(element) {
    let content = element.nextElementSibling;
    while (content && !content.classList.contains('allynav__footer__accordion__content')) {
      content = content.nextElementSibling;
    }
    return content;
  }

  function closeAllAccordions() {
    document.querySelectorAll('.allynav__footer__accordion__content').forEach(c => {
      c.style.display = 'none';
    });

    document.querySelectorAll('.allynav__footer__accordion__title').forEach(title => {
      toggleIcons(title, false);
    });
  }

  function toggleIcons(title, isOpen) {
    const minusIcon = title.querySelector('.allynav__footer__accordion__title__minus');
    const plusIcon = title.querySelector('.allynav__footer__accordion__title__plus');

    if (minusIcon && plusIcon) {
      minusIcon.style.display = isOpen ? 'inline-flex' : 'none';
      plusIcon.style.display = isOpen ? 'none' : 'inline-flex';
    }
  }

  function destroyAccordion() {
    document.querySelectorAll('.allynav__footer__accordion__title').forEach(title => {
      if (title._accordionListener) {
        title.removeEventListener('click', title._accordionListener);
        delete title._accordionListener;
      }

      const content = findNextContent(title);
      if (content) {
        content.style.display = ''; // 恢复默认显示
      }

      toggleIcons(title, false);
    });
  }

  // 初始检查
  maybeInitAccordion();

  // 监听窗口变化
  window.addEventListener('resize', maybeInitAccordion);
});
</script>				</div>
				</div>
				</div>
